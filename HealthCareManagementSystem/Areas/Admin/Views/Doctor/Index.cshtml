@model IEnumerable<HealthCareManagementSystem.Models.Doctor>

@{
    ViewData["Title"] = "Doctors";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            Doctors
        </h2>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Doctor
        </a>

    </div>

    <table class="table table-bordered table-hover align-middle shadow">

        <thead class="table-dark">

            <tr>
                <th style="width:120px">Image</th>
                <th>Name</th>
                <th>Specialization</th>
                <th>Clinic</th>
                <th style="width:220px">Actions</th>
            </tr>

        </thead>

        <tbody>

            @if (Model.Any())
            {
                @foreach (var doctor in Model)
                {
                    <tr>

                        <td class="text-center">

                            @if (!string.IsNullOrEmpty(doctor.ImageName))
                            {
                                <img src="~/Images/Doctors/@doctor.ImageName"
                                     class="rounded-circle shadow"
                                     width="70"
                                     height="70"
                                     style="object-fit:cover;" />
                            }
                            else
                            {
                                <img src="~/Images/Doctors/default-doctor.png"
                                     class="rounded-circle shadow"
                                     width="70"
                                     height="70"
                                     style="object-fit:cover;" />
                            }

                        </td>

                        <td>@doctor.Name</td>

                        <td>@doctor.Specialization</td>

                        <td>@doctor.Clinic.Name</td>

                        <td>

                            <a asp-action="Update"
                               asp-route-id="@doctor.Id"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@doctor.Id"
                               class="btn btn-danger btn-sm">
                                Delete
                            </a>

                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>

                    <td colspan="5"
                        class="text-center text-muted py-4">

                        No Doctors Found

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>