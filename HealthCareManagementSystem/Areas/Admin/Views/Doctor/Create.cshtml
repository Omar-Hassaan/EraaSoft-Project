@model HealthCareManagementSystem.ViewModels.DoctorVM

@{
    ViewData["Title"] = "Create Doctor";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0">

                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        Create Doctor
                    </h3>
                </div>

                <div class="card-body">

                    <form asp-action="Create"
                          method="post"
                          enctype="multipart/form-data">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="mb-3">

                            <label asp-for="Name"
                                   class="form-label">
                            </label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Enter doctor name" />

                            <span asp-validation-for="Name"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Specialization"
                                   class="form-label">
                            </label>

                            <input asp-for="Specialization"
                                   class="form-control"
                                   placeholder="Enter specialization" />

                            <span asp-validation-for="Specialization"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="ClinicId"
                                   class="form-label">
                                Clinic
                            </label>

                            <select asp-for="ClinicId"
                                    asp-items="ViewBag.Clinics"
                                    class="form-select">

                                <option value="">
                                    -- Select Clinic --
                                </option>

                            </select>

                            <span asp-validation-for="ClinicId"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Image"
                                   class="form-label">
                            </label>

                            <input asp-for="Image"
                                   class="form-control" />

                            <span asp-validation-for="Image"
                                  class="text-danger"></span>

                        </div>

                        <div class="d-flex justify-content-between">

                            <a asp-action="Index"
                               class="btn btn-secondary">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn btn-primary">
                                Save Doctor
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}