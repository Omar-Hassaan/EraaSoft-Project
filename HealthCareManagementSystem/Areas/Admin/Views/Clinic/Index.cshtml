@model IEnumerable<HealthCareManagementSystem.Models.Clinic>

@{
    ViewData["Title"] = "Clinics";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            Clinics
        </h2>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Clinic
        </a>

    </div>

    <table class="table table-bordered table-hover align-middle shadow-sm">

        <thead class="table-dark">

            <tr>
                <th style="width:120px">Image</th>
                <th>Name</th>
                <th>Address</th>
                <th>Phone Number</th>
                <th>Description</th>
                <th style="width:220px">Actions</th>
            </tr>

        </thead>

        <tbody>

            @if (Model.Any())
            {
                @foreach (var clinic in Model)
                {
                    <tr>

                        <td class="text-center">

                            @if (!string.IsNullOrEmpty(clinic.ImageName))
                            {
                                <img src="~/Images/Clinics/@clinic.ImageName"
                                     width="80"
                                     height="80"
                                     class="rounded shadow-sm"
                                     style="object-fit:cover" />
                            }
                            else
                            {
                                <img src="~/Images/Clinics/default-clinic.png"
                                     width="80"
                                     height="80"
                                     class="rounded shadow-sm"
                                     style="object-fit:cover" />
                            }

                        </td>

                        <td>@clinic.Name</td>

                        <td>@clinic.Address</td>

                        <td>@clinic.PhoneNumber</td>

                        <td>@clinic.Description</td>

                        <td>

                            @* <a asp-action="Details"
                               asp-route-id="@clinic.Id"
                               class="btn btn-info btn-sm">
                                Details
                            </a> *@

                            <a asp-action="Update"
                               asp-route-id="@clinic.Id"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@clinic.Id"
                               class="btn btn-danger btn-sm">
                                Delete
                            </a>

                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>

                    <td colspan="6" class="text-center text-muted py-4">

                        No Clinics Found

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>