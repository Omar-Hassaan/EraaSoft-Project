@model HealthCareManagementSystem.ViewModels.NewPasswordVM

@{
    ViewData["Title"] = "Reset New Password";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<style>
    body {
        background: linear-gradient(to right, #0f172a, #1e293b);
        min-height: 100vh;
    }

    .reset-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .reset-card {
        width: 100%;
        max-width: 500px;
        background: #fff;
        border-radius: 20px;
        padding: 40px 35px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    .reset-title {
        text-align: center;
        font-size: 32px;
        font-weight: bold;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .reset-subtitle {
        text-align: center;
        color: #64748b;
        margin-bottom: 30px;
    }

    .form-control {
        height: 50px;
        border-radius: 12px;
        font-size: 16px;
    }

    .form-label {
        font-weight: 600;
        color: #1e293b;
    }

    .reset-btn {
        width: 100%;
        height: 50px;
        border-radius: 12px;
        border: none;
        background: #2563eb;
        font-size: 18px;
        font-weight: 600;
        transition: 0.3s;
    }

        .reset-btn:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
        }

    .back-link {
        text-align: center;
        margin-top: 20px;
    }

        .back-link a {
            text-decoration: none;
            color: #2563eb;
            font-weight: 500;
        }

            .back-link a:hover {
                text-decoration: underline;
            }
</style>

<div class="reset-container">

    <div class="reset-card">

        <h1 class="reset-title">Reset Password</h1>

        <p class="reset-subtitle">
            Create a new secure password for your account
        </p>

        <form asp-action="NewPassword">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <input asp-for="UserId" hidden />
            <input asp-for="Token" hidden />

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>

                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="Enter new password" />

                <span asp-validation-for="Password"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmedPassword"
                       class="form-label">
                </label>

                <input asp-for="ConfirmedPassword"
                       type="password"
                       class="form-control"
                       placeholder="Confirm new password" />

                <span asp-validation-for="ConfirmedPassword"
                      class="text-danger">
                </span>
            </div>

            <button type="submit"
                    class="btn btn-primary reset-btn">
                Reset Password
            </button>

        </form>

        <div class="back-link">
            <a asp-action="Login">
                Back To Login
            </a>
        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<partial name="_Notification" />
