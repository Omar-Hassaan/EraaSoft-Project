@model HealthCareManagementSystem.ViewModels.ResendEmailConfirmationVM

@{
    ViewData["Title"] = "Resend Email Confirmation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background-color: #0d1117;
    }

    .resend-container {
        min-height: 90vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .resend-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 20px;
        padding: 40px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 0 25px rgba(0,0,0,0.4);
        color: white;
    }

    .resend-title {
        text-align: center;
        font-size: 30px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .resend-subtitle {
        text-align: center;
        color: #8b949e;
        margin-bottom: 30px;
        font-size: 15px;
    }

    .form-control {
        background-color: #0d1117;
        border: 1px solid #30363d;
        color: white;
        padding: 12px;
        border-radius: 10px;
    }

        .form-control:focus {
            background-color: #0d1117;
            color: white;
            border-color: #58a6ff;
            box-shadow: none;
        }

    label {
        margin-bottom: 8px;
        font-weight: 500;
    }

    .btn-send {
        width: 100%;
        background: #238636;
        border: none;
        padding: 12px;
        border-radius: 10px;
        color: white;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-send:hover {
            background: #2ea043;
        }

    .back-link {
        text-align: center;
        margin-top: 20px;
    }

        .back-link a {
            color: #58a6ff;
            text-decoration: none;
            transition: 0.3s;
        }

            .back-link a:hover {
                color: #79c0ff;
            }

    .text-danger {
        font-size: 14px;
    }
</style>

<div class="container resend-container">

    <div class="resend-card">

        <div class="resend-title">
            Verify Your Account
        </div>

        <div class="resend-subtitle">
            Enter your username or email to resend the confirmation email
        </div>

        <form asp-action="ResendEmailConfairmation">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="UserNameOrEmail"></label>

                <input asp-for="UserNameOrEmail"
                       class="form-control"
                       placeholder="Enter username or email" />

                <span asp-validation-for="UserNameOrEmail"
                      class="text-danger"></span>
            </div>

            <button type="submit" class="btn-send">
                Send Confirmation Email
            </button>

        </form>

        <div class="back-link">
            <a asp-action="Login">
                Back to Login
            </a>
        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<partial name="_Notification" />
